{
  "manifest_version": 3,
  "name": "Alpenaufschlag",
  "version": "1.5",
  "description": "Compare prices from web shops between Austria, Germany and Slovakia.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "js": ["scripts/content/shared.js", "scripts/content/dm/content.js"],
      "matches": ["https://www.dm.at/*", "https://www.dm.de/*"]
    },
    {
      "js": ["scripts/content/shared.js", "scripts/content/ikea/content.js"],
      "matches": [
        "https://www.ikea.com/at/de/*",
        "https://www.ikea.com/de/de/*",
        "https://www.ikea.com/sk/sk/*",
        "https://www.ikea.com/cz/cs/*",
        "https://www.ikea.com/hu/hu/*"
      ]
    },
    {
      "js": ["scripts/content/shared.js", "scripts/content/xxxlutz/content.js"],
      "matches": ["https://www.xxxlutz.at/*", "https://www.xxxlutz.de/*"]
    },
    {
      "js": ["scripts/content/shared.js", "scripts/content/mueller/content.js"],
      "matches": ["https://www.mueller.at/*", "https://www.mueller.de/*"]
    },
    {
      "js": ["scripts/content/shared.js", "scripts/content/thalia/content.js"],
      "matches": ["https://www.thalia.at/*", "https://www.thalia.de/*"]
    }
  ],
  "permissions": ["storage"],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "host_permissions": [
    "https://products.dm.de/product/*",
    "https://www.ikea.com/at/de/*",
    "https://www.ikea.com/de/de/*",
    "https://www.ikea.com/sk/sk/*",
    "https://www.ikea.com/cz/cs/*",
    "https://www.ikea.com/hu/hu/*",
    "https://www.xxxlutz.at/*",
    "https://www.xxxlutz.de/*",
    "https://www.mueller.at/*",
    "https://www.mueller.de/*",
    "https://www.thalia.at/*",
    "https://www.thalia.de/*"
  ]
}
